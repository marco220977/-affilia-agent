# Exchange credentials
EXCHANGE=binance
API_KEY=your_api_key_here
API_SECRET=your_api_secret_here

# Trading parameters
SYMBOLS=BTC/USDT,ETH/USDT,BNB/USDT
TIMEFRAME=5m
DRY_RUN=true

# Capital management
TOTAL_CAPITAL=1000.0
MAX_POSITION_SIZE_PCT=2.0
MAX_DAILY_LOSS_PCT=3.0
MAX_CONCURRENT_POSITIONS=3
MAX_DRAWDOWN_PCT=10.0

# Target & risk per trade
PROFIT_TARGET_PCT=1.0
STOP_LOSS_PCT=0.5
TRAILING_STOP_ACTIVATE_PCT=0.7
TRAILING_STOP_TRAIL_PCT=0.3

# Analysis thresholds
MIN_CONFIDENCE=65.0
LOOP_INTERVAL_SECONDS=60

# Vercel — cron job protection (generate a random secret, add it to Vercel env vars too)
CRON_SECRET=change_me_to_a_random_string

# Vercel KV — persistent state across serverless calls (optional but recommended)
# Add KV_REST_API_URL and KV_REST_API_TOKEN from the Vercel KV store dashboard
# KV_REST_API_URL=https://xxxxx.kv.vercel-storage.com
# KV_REST_API_TOKEN=your_token_here
